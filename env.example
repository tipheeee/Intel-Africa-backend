# ── Supabase ──────────────────────────────────────
# Get from: supabase.com → your project → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY

# ── Proxycurl (LinkedIn data) ──────────────────────
# Get from: nubela.co/proxycurl → free $10 trial
PROXYCURL_API_KEY=YOUR_PROXYCURL_KEY

# ── DataForSEO (Website traffic) ──────────────────
# Get from: dataforseo.com → register free
DATAFORSEO_LOGIN=YOUR_EMAIL
DATAFORSEO_PASSWORD=YOUR_PASSWORD

# ── Crunchbase (Funding data) ─────────────────────
# Get from: data.crunchbase.com → $29/month
CRUNCHBASE_API_KEY=YOUR_CRUNCHBASE_KEY

# ── Meta Ad Library (FREE!) ───────────────────────
# Get from: developers.facebook.com
# Create App → Marketing API → Graph API Explorer → Generate Token → add ads_read permission
META_ACCESS_TOKEN=YOUR_META_TOKEN

# ── Server ────────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:3000
